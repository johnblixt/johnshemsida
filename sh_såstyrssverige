<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Så styrs Sverige - Repetitionsspel</title>
  
  <!-- Laddar in React -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  
  <!-- Laddar in Babel (för att läsa koden i webbläsaren) -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  
  <!-- Laddar in Tailwind CSS för designen -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50">
  <div id="root"></div>

  <script type="text/babel">
    const { useState } = React;

    // --- IKONER (Ersätter Lucide-react för att fungera utan installation) ---
    const BookOpen = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
    );
    const Trophy = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
    );
    const RefreshCw = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
    );
    const CheckCircle2 = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
    );
    const XCircle = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
    );
    const ChevronRight = ({ className }) => (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="m9 18 6-6-6-6"/></svg>
    );

    // --- DATA ---
    const allQuestions = [
      {
        question: "Vilken av dessa är INTE en av Sveriges fyra grundlagar?",
        correct: "Skollagen",
        incorrect: ["Regeringsformen", "Tryckfrihetsförordningen", "Successionsordningen"]
      },
      {
        question: "Vad betyder ordet parlamentarism?",
        correct: "Att regeringen måste ha stöd av riksdagen för att få styra.",
        incorrect: ["Att kommunerna får bestämma själva.", "Att alla i Sverige får rösta.", "Att kungen bestämmer."]
      },
      {
        question: "Hur många personer sitter i Sveriges riksdag?",
        correct: "349",
        incorrect: ["340", "394", "299"]
      },
      {
        question: "Vad kallas det när flera partier jobbar ihop för att bilda regering?",
        correct: "Koalition",
        incorrect: ["Opposition", "Majoritet", "Utskott"]
      },
      {
        question: "Vem leder arbetet i riksdagen och föreslår statsminister?",
        correct: "Talmannen",
        incorrect: ["Statsministern", "Kungen", "Oppositionsledaren"]
      },
      {
        question: "Vilka ansvarar oftast för sjukhus och bussar/tåg?",
        correct: "Regionen",
        incorrect: ["Kommunen", "Riksdagen", "EU"]
      },
      {
        question: "Vilka ansvarar för skolor, äldreomsorg och vatten?",
        correct: "Kommunen",
        incorrect: ["Regionen", "Regeringen", "Polisen"]
      },
      {
        question: "Vad är en 'politisk vilde'?",
        correct: "En person som lämnar sitt parti men stannar kvar i riksdagen.",
        incorrect: ["En person som bråkar utanför riksdagen.", "En minister som får sparken.", "En partiledare utan makt."]
      },
      {
        question: "Vad är en minoritetsregering?",
        correct: "En regering som har mindre än hälften av platserna i riksdagen.",
        incorrect: ["En regering med bara ett parti.", "En regering med mer än hälften av platserna i riksdagen.", "En regering utan statsminister."]
      },
      {
        question: "Vad är skillnaden på en proposition och en motion?",
        correct: "Regeringen skriver propositioner, riksdagen skriver motioner.",
        incorrect: ["Propositioner är nya lagar, motioner är gamla lagar.", "Kungen skriver propositioner, folket skriver motioner.", "Båda är samma sak."]
      },
      {
        question: "Innan ett förslag blir lag undersöks det noga av experter. Vad kallas det?",
        correct: "En utredning",
        incorrect: ["Ett betänkande", "En röstning", "En varning"]
      },
      {
        question: "När utredningen är klar får ofta myndigheter läsa och tycka till om förslaget. Vad kallas det?",
        correct: "Remiss",
        incorrect: ["Votering", "Lagråd", "Anmälan"]
      },
      {
        question: "I riksdagen finns det små grupper som jobbar med olika frågor. Vad kallas de?",
        correct: "Utskott",
        incorrect: ["Departement", "Nämnder", "Partier"]
      },
      {
        question: "Till slut samlas hela riksdagen och röstar ja eller nej till den nya lagen. Vad kallas röstningen?",
        correct: "Votering",
        incorrect: ["Interpellation", "Debatt", "Remiss"]
      },
      {
        question: "Vilken är en stor fördel med EU när det gäller resor och jobb?",
        correct: "Svenskar kan lätt bo, jobba och plugga i andra EU-länder.",
        incorrect: ["Svenskar slipper betala skatt i andra EU-länder.", "EU betalar alla våra resor.", "Vi behöver aldrig visa pass."]
      },
      {
        question: "Hur hjälper EU svenska företag?",
        correct: "Det är lättare att sälja varor i Europa eftersom tullar är borta.",
        incorrect: ["Företag behöver inte betala ut löner.", "EU ger företagen gratis material.", "Företagen slipper följa miljöregler."]
      },
      {
        question: "Vilken nackdel med EU brukar kritiker prata om när det gäller makt?",
        correct: "Sverige måste ibland följa EU fast vi egentligen inte vill.",
        incorrect: ["EU väljer Sveriges statsminister.", "Sverige får inte ha någon egen polis.", "Svenskar får inte rösta i riksdagsvalet."]
      },
      {
        question: "En annan nackdel med EU handlar om pengar och krångel. Vad menas?",
        correct: "Det kostar mycket pengar att vara med och reglerna kan vara krångliga.",
        incorrect: ["Sverige tvingades byta till Euro.", "EU tar alla pengar från kommunerna.", "Svenska företag måste betala dubbel skatt."]
      },
      {
        question: "Varför är Sveriges grundlagar så viktiga?",
        correct: "De är grunden för samhället och skyddar vår demokrati.",
        incorrect: ["De bestämmer hur mycket skatt vi ska betala.", "De ger kungen all makt.", "Det är de enda lagarna polisen får använda."]
      },
      {
        question: "Det krävs två riksdagsbeslut och ett val för att ändra en grundlag. Varför är det så svårt?",
        correct: "För att reglerna inte ska ändras för snabbt och folket ska få säga sitt.",
        incorrect: ["För att det är dyrt att trycka nya lagböcker.", "För att kungen ska hinna läsa lagen.", "För att EU måste godkänna ändringen."]
      }
    ];

    // --- HJÄLPFUNKTIONER ---
    const shuffleArray = (array) => {
      const shuffled = [...array];
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      return shuffled;
    };

    // --- HUVUDKOMPONENT ---
    function App() {
      const [gameState, setGameState] = useState('start');
      const [questions, setQuestions] = useState([]);
      const [currentQuestionIndex, setCurrentQuestionIndex] = useState(0);
      const [currentOptions, setCurrentOptions] = useState([]);
      const [selectedOption, setSelectedOption] = useState(null);
      const [isAnswered, setIsAnswered] = useState(false);
      const [score, setScore] = useState(0);

      const startGame = () => {
        const shuffledQuestions = shuffleArray(allQuestions);
        setQuestions(shuffledQuestions);
        setScore(0);
        setCurrentQuestionIndex(0);
        setGameState('playing');
        loadQuestion(shuffledQuestions[0]);
      };

      const loadQuestion = (questionData) => {
        setSelectedOption(null);
        setIsAnswered(false);
        const options = [questionData.correct, ...questionData.incorrect];
        setCurrentOptions(shuffleArray(options));
      };

      const handleOptionClick = (option) => {
        if (isAnswered) return;
        setSelectedOption(option);
        setIsAnswered(true);
        if (option === questions[currentQuestionIndex].correct) {
          setScore(score + 1);
        }
      };

      const handleNext = () => {
        if (currentQuestionIndex + 1 < questions.length) {
          const nextIndex = currentQuestionIndex + 1;
          setCurrentQuestionIndex(nextIndex);
          loadQuestion(questions[nextIndex]);
        } else {
          setGameState('result');
        }
      };

      // --- RENDERING ---
      if (gameState === 'start') {
        return (
          <div className="min-h-screen flex items-center justify-center p-4">
            <div className="bg-white max-w-md w-full rounded-2xl shadow-xl overflow-hidden">
              <div className="bg-blue-600 p-8 text-center text-white">
                <BookOpen className="w-16 h-16 mx-auto mb-4 opacity-90" />
                <h1 className="text-3xl font-bold mb-2">Så styrs Sverige</h1>
                <p className="text-blue-100">Ett repetitionsspel inför provet</p>
              </div>
              <div className="p-8 text-center">
                <p className="text-slate-600 mb-8">
                  Spelet innehåller {allQuestions.length} frågor om grundlagar, lagstiftningsprocessen, riksdag/regering och EU. 
                  Frågorna och svarsalternativen slumpas varje gång du spelar!
                </p>
                <button 
                  onClick={startGame}
                  className="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-xl transition-colors shadow-md text-lg"
                >
                  Starta spelet
                </button>
              </div>
            </div>
          </div>
        );
      }

      if (gameState === 'result') {
        const percentage = Math.round((score / questions.length) * 100);
        let message = "";
        if (percentage === 100) message = "Alla rätt! Du är en expert på svensk politik!";
        else if (percentage >= 75) message = "Snyggt jobbat! Du har stenkoll på det mesta.";
        else if (percentage >= 50) message = "Bra försök! Du kan en hel del, men repetera lite till.";
        else message = "Läs på lite mer i häftet och försök igen. Du klarar det nästa gång!";

        return (
          <div className="min-h-screen flex items-center justify-center p-4">
            <div className="bg-white max-w-md w-full rounded-2xl shadow-xl p-8 text-center">
              <Trophy className={`w-20 h-20 mx-auto mb-4 ${percentage >= 75 ? 'text-yellow-500' : 'text-slate-400'}`} />
              <h2 className="text-3xl font-bold text-slate-800 mb-2">Ditt resultat</h2>
              <p className="text-5xl font-black text-blue-600 mb-4">{score} / {questions.length}</p>
              <p className="text-slate-600 mb-8 font-medium">{message}</p>
              <button 
                onClick={startGame}
                className="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors shadow-md"
              >
                <RefreshCw className="w-5 h-5" />
                Spela igen
              </button>
            </div>
          </div>
        );
      }

      const currentQ = questions[currentQuestionIndex];

      return (
        <div className="min-h-screen flex flex-col items-center py-8 p-4">
          <div className="w-full max-w-md">
            
            {/* Progress bar */}
            <div className="mb-6">
              <div className="flex justify-between text-sm font-semibold text-slate-500 mb-2 px-1">
                <span>Fråga {currentQuestionIndex + 1} av {questions.length}</span>
                <span>Poäng: {score}</span>
              </div>
              <div className="h-2 w-full bg-slate-200 rounded-full overflow-hidden">
                <div 
                  className="h-full bg-blue-600 transition-all duration-300"
                  style={{ width: `${((currentQuestionIndex) / questions.length) * 100}%` }}
                ></div>
              </div>
            </div>

            {/* Frågekort */}
            <div className="bg-white rounded-2xl shadow-lg p-6 mb-6">
              <h2 className="text-xl font-bold text-slate-800 leading-snug">
                {currentQ.question}
              </h2>
            </div>

            {/* Svarsalternativ */}
            <div className="space-y-3">
              {currentOptions.map((option, index) => {
                let btnClasses = "w-full text-left p-4 rounded-xl border-2 transition-all font-medium text-[15px] sm:text-base flex items-center justify-between gap-3 ";
                
                if (!isAnswered) {
                  btnClasses += "border-slate-200 bg-white text-slate-700 hover:border-blue-400 hover:bg-blue-50 active:scale-[0.98]";
                } else {
                  if (option === currentQ.correct) {
                    btnClasses += "border-green-500 bg-green-50 text-green-800";
                  } else if (option === selectedOption) {
                    btnClasses += "border-red-500 bg-red-50 text-red-800";
                  } else {
                    btnClasses += "border-slate-100 bg-slate-50 text-slate-400 opacity-60";
                  }
                }

                return (
                  <button
                    key={index}
                    onClick={() => handleOptionClick(option)}
                    disabled={isAnswered}
                    className={btnClasses}
                  >
                    <span>{option}</span>
                    {isAnswered && option === currentQ.correct && (
                      <CheckCircle2 className="w-6 h-6 text-green-500 shrink-0" />
                    )}
                    {isAnswered && option === selectedOption && option !== currentQ.correct && (
                      <XCircle className="w-6 h-6 text-red-500 shrink-0" />
                    )}
                  </button>
                );
              })}
            </div>

            {/* Nästa-knapp */}
            {isAnswered && (
              <div className="mt-8 transition-opacity duration-300">
                <button
                  onClick={handleNext}
                  className="w-full bg-slate-800 hover:bg-slate-900 text-white font-semibold py-4 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors shadow-lg active:scale-[0.98]"
                >
                  {currentQuestionIndex + 1 === questions.length ? 'Se resultat' : 'Nästa fråga'}
                  <ChevronRight className="w-5 h-5" />
                </button>
              </div>
            )}

          </div>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
